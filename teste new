<!DOCTYPE html>
<html lang="pt">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Portal Colaborador</title>

<style>
body{
    margin:0;
    font-family:Arial;
    background:#eef2f7;
}

/* HEADER */
.header{
    background:#111827;
    color:white;
    padding:15px 20px;
    font-size:18px;
    font-weight:bold;
}

/* LAYOUT */
.container{
    display:grid;
    grid-template-columns:280px 1fr;
    gap:20px;
    padding:20px;
}

/* CARDS */
.card{
    background:white;
    border-radius:12px;
    padding:20px;
    box-shadow:0 4px 10px rgba(0,0,0,0.05);
}

/* BUTTONS */
button{
    width:100%;
    padding:12px;
    margin:6px 0;
    border:none;
    border-radius:8px;
    cursor:pointer;
    font-weight:bold;
    transition:0.2s;
}

button:hover{
    opacity:0.85;
}

/* ESTADOS */
.btn-green{background:#22c55e;color:white;}
.btn-yellow{background:#f59e0b;color:white;}
.btn-red{background:#ef4444;color:white;}
.btn-blue{background:#3b82f6;color:white;}
.btn-dark{background:#111827;color:white;}

/* FORM */
input,select{
    width:100%;
    padding:10px;
    margin:6px 0;
    border:1px solid #d1d5db;
    border-radius:8px;
    outline:none;
}

/* TIMER */
.timer{
    font-size:34px;
    text-align:center;
    margin:15px 0;
    font-weight:bold;
    color:#111827;
}

/* STATUS */
.status{
    padding:10px;
    background:#f3f4f6;
    border-radius:8px;
    margin-top:10px;
    font-weight:bold;
}
</style>
</head>

<body>

<div class="header">
Portal do Colaborador
</div>

<div class="container">

<!-- ESQUERDA: ESTADOS -->
<div class="card">
<h3>Estados</h3>

<button class="btn-green" onclick="setEstado('Disponivel')">Disponível</button>
<button class="btn-yellow" onclick="setEstado('Pausa1')">Pausa 1</button>
<button class="btn-yellow" onclick="setEstado('Pausa2')">Pausa 2</button>
<button class="btn-red" onclick="setEstado('Refeicao')">Refeição</button>
<button class="btn-blue" onclick="setEstado('Formacao')">Formação</button>

<div class="status" id="estadoAtual">Estado: -</div>
</div>

<!-- DIREITA: PRODUÇÃO -->
<div class="card">

<h3>Produção</h3>

<label>Nº Processo</label>
<input id="processo">

<label>Nº Documentos</label>
<input id="documentos" type="number">

<label>Tarefa Finalizada</label>
<select id="tarefa">
<option value="1">Opção 1</option>
<option value="2">Opção 2</option>
</select>

<div class="timer" id="timer">00:00:00</div>

<button class="btn-green" onclick="iniciar()">Iniciar</button>
<button class="btn-red" onclick="parar()">Parar</button>
<button class="btn-dark" onclick="enviarProducao()">Guardar Produção</button>

</div>

</div>

<script>

// ================= SUPABASE =================
const user="EX04904";
const nome="Telma Sofia Pereira Rosa";

const SUPABASE_URL = 'https://bijndfsxrzjviwrdvwms.supabase.co';
const SUPABASE_API_KEY = 'SUA_KEY_AQUI';

// ================= ESTADOS =================
async function setEstado(tipo){

    document.getElementById("estadoAtual").innerText =
        "Estado: " + tipo;

    await fetch(`${SUPABASE_URL}/rest/v1/BPO_registosNSS`, {
        method:"POST",
        headers:{
            "Content-Type":"application/json",
            "apikey":SUPABASE_API_KEY,
            "Authorization":"Bearer "+SUPABASE_API_KEY,
            "Prefer":"return=minimal"
        },
        body:JSON.stringify({
            user:user,
            nome:nome,
            tipo:tipo,
            inicio:new Date().toISOString()
        })
    });

}

// ================= TIMER =================
let segundos=0;
let intervalo=null;

function tick(){

    segundos++;

    let h=String(Math.floor(segundos/3600)).padStart(2,'0');
    let m=String(Math.floor((segundos%3600)/60)).padStart(2,'0');
    let s=String(segundos%60).padStart(2,'0');

    document.getElementById("timer").innerText =
        `${h}:${m}:${s}`;
}

function iniciar(){
    if(!intervalo){
        intervalo=setInterval(tick,1000);
    }
}

function parar(){
    clearInterval(intervalo);
    intervalo=null;
}

// ================= PRODUÇÃO =================
async function enviarProducao(){

    await fetch(`${SUPABASE_URL}/rest/v1/BPO_dadosprodução`, {
        method:"POST",
        headers:{
            "Content-Type":"application/json",
            "apikey":SUPABASE_API_KEY,
            "Authorization":"Bearer "+SUPABASE_API_KEY,
            "Prefer":"return=minimal"
        },
        body:JSON.stringify({
            user:user,
            nome:nome,
            processo:document.getElementById("processo").value,
            documentos:document.getElementById("documentos").value,
            tarefa_finalizada:document.getElementById("tarefa").value,
            tempo:document.getElementById("timer").innerText,
            data:new Date().toISOString()
        })
    });

    alert("Produção enviada!");

    segundos=0;
    document.getElementById("timer").innerText="00:00:00";
}

</script>

</body>
</html>
